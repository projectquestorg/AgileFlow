    "audit": {
      "enabled": false
    },
    "council": {
      "enabled": false
    },
    "delivery": {
      "enabled": false
    },
    "docs": {
      "enabled": false
    },
    "engineering": {
      "enabled": true
    },
    "ideation": {
      "enabled": false
    },
    "migration": {
      "enabled": false
    },
    "planning": {
      "enabled": false
    },
    "research": {
      "enabled": false
    },
    "seo": {
      "enabled": false
    }
