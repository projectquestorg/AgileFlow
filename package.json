{
  "name": "agileflow-monorepo",
  "version": "3.5.0",
  "private": true,
  "description": "AgileFlow monorepo - CLI, website, and documentation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:website": "npm run dev -w apps/website",
    "dev:docs": "npm run dev -w apps/docs",
    "dev:cli": "npm run start -w apps/cli",
    "build:website": "npm run build -w apps/website",
    "build:docs": "npm run build -w apps/docs",
    "build:all": "npm run build --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "test:cli": "npm run test -w apps/cli",
    "test:all": "npm run test --workspaces --if-present",
    "doctor": "npm run doctor -w apps/cli",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projectquestorg/AgileFlow.git"
  },
  "author": "AgileFlow Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "tailwindcss": "3.4.1"
  },
  "dependencies": {
    "agileflow": "^2.61.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "lint-staged": {
    "apps/cli/**/*.{js,json,md,yaml,yml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "overrides": {
    "diff": ">=8.0.3",
    "xml2js": ">=0.5.0",
    "lodash-es": ">=4.17.23",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
